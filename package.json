{
  "name": "fistik",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "next dev -H 0.0.0.0",
    "dev:clean": "npm run clean && npm run dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "open:lan-firewall": "powershell -ExecutionPolicy Bypass -File scripts/open-lan-firewall.ps1",
    "build": "next build",
    "start": "next start",
    "generate:menu": "node scripts/generate-menu-seed.mjs",
    "generate:prices": "node scripts/generate-price-update.mjs",
    "sync:prices": "node scripts/sync-prices-to-supabase.mjs",
    "sync:b2b-prices": "node scripts/sync-b2b-prices-to-supabase.mjs",
    "check:env": "node scripts/check-env.mjs",
    "release:check": "npm run check:env && npm run build",
    "lint": "eslint"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
